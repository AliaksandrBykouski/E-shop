#!/bin/sh
echo "🚀 Запускается pre-commit hook (eslint + tsc-files только по staged файлам)"

# Получаем staged JS/TS файлы
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(js|ts|jsx|tsx)$')

if [ -n "$STAGED_FILES" ]; then
  echo "🔍 Проверка ESLint..."
  npx eslint $STAGED_FILES
  if [ $? -ne 0 ]; then
    echo "❌ ESLint нашёл ошибки, коммит отменён!"
    exit 1
  fi

  echo "🔍 Проверка типов TypeScript..."
  npx tsc-files --noEmit $STAGED_FILES
  if [ $? -ne 0 ]; then
    echo "❌ Ошибки типов, коммит отменён!"
    exit 1
  fi
fi

echo "✅ Все staged-файлы прошли проверки, продолжаем коммит..."
